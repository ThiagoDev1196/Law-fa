---
import ServiceCard from "./ServiceCard.astro";
---

<section class=" bg-primary pt-10">

    <h3 class="text-4xl text-center font-bold sm:text-5xl pb-8 md:pb-12 lg:text-6xl border-b border-gold w-auto">Our legal services</h3>

  <div class="services-container py-10 flex flex-col sm:flex-wrap sm:flex-row items-center justify-center p-4 space-y-6 md:flex-row sm:space-x-6 md:items-start xl:space-x-8">

    <ServiceCard
      service="Civil Law"
      img="/law-fa/section-pics/service-1.png"
      description="Contracts, inheritance and wealth management"
    />
    <ServiceCard
      service="Criminal Law"
      img="/law-fa/section-pics/service-2.png"
      description="Defense in criminal proceedings and legal advice"
    />
    <ServiceCard
      service="Labor Law"
      img="/law-fa/section-pics/service-3.png"
      description="Business consulting, dismissals and wage claims"
    />
  </div>
</section>
